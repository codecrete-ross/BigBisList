            }
          ],
          "text": ": Bloodthirst should be used on cooldown."
        },
        {
          "entities": [
            {
              "id": 1680,
              "name": "Whirlwind",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=1680/whirlwind"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Fury Warrior DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=1680/whirlwind",
              "text": "Whirlwind"
            }
          ],
          "text": "Whirlwind : Whirlwind is good to convert extra Rage into damage, but make sure you always save 30 rage for BT when it comes off cooldown."
        },
        {
          "entities": [
            {
              "id": 29801,
              "name": "",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=29801"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Fury Warrior DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=29801",
              "text": ""
            }
          ],
          "text": ": You'll want to refresh Rampage before the buff falls off."
        },
        {
          "entities": [
            {
              "id": 5308,
              "name": "Execute",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=5308/execute"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Fury Warrior DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=5308/execute",
              "text": "Execute"
            }
          ],
          "text": "Execute : Use Execute if your target is below 20% and the next attack won't be enough to kill the target."
        },
        {
          "entities": [
            {
              "id": 25225,
              "name": "",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=25225"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Fury Warrior DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=25225",
              "text": ""
            }
          ],
          "text": ": Convert spare rage into Sunder Armor to increase damage done to your target."
        },
        {
          "entities": [
            {
              "id": 78,
              "name": "",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=78"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Fury Warrior DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=78",
              "text": ""
            }
          ],
          "text": ": Only use Heroic Strike to dump extra rage if you are about to cap your rage bar."
        },
        {
          "entities": [
            {
              "id": 12328,
              "name": "",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=12328"
