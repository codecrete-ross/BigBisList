  "sections": [
    {
      "data_family": "leveling",
      "entries": [
        {
          "entities": [],
          "level_range": "60",
          "section": "Best Talent Builds for Leveling as Beast Mastery Hunter DPS in TBC Classic",
          "source_links": [],
          "text": "At level 60, you should only be 10 talent points into the Marksmanship tree, with 5/5 Lethal Shots and 5/5 Efficiency."
        },
        {
          "entities": [],
          "level_range": null,
          "section": "Best Talent Builds for Leveling as Beast Mastery Hunter DPS in TBC Classic",
          "source_links": [],
          "text": "At 61 you should take Aimed Shot"
        },
        {
          "entities": [],
          "level_range": null,
          "section": "Best Talent Builds for Leveling as Beast Mastery Hunter DPS in TBC Classic",
          "source_links": [],
          "text": "At levels 62/63 pick up 2/2 Rapid Killing"
        },
        {
          "entities": [],
          "level_range": null,
          "section": "Best Talent Builds for Leveling as Beast Mastery Hunter DPS in TBC Classic",
          "source_links": [],
          "text": "At levels 64/65 pick up 2/2 Go for the Throat"
        },
        {
          "entities": [],
          "level_range": "65-70",
          "section": "Best Talent Builds for Leveling as Beast Mastery Hunter DPS in TBC Classic",
          "source_links": [],
          "text": "At levels 65-70 pick up 5/5 Mortal Shots"
        }
      ],
      "heading": "Best Talent Builds for Leveling as Beast Mastery Hunter DPS in TBC Classic"
    },
    {
      "data_family": "leveling",
      "entries": [
        {
          "entities": [
            {
              "id": 75,
              "name": "Auto Shot",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=75/auto-shot"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Beast Mastery Hunter DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=75/auto-shot",
              "text": "Auto Shot"
            }
          ],
          "text": "Auto Shot will always be the start of your rotation. You never want to \"clip\" your Auto Shot with any other abilities in your rotation."
        },
        {
          "entities": [
            {
              "id": 14287,
              "name": "Arcane Shot",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=14287"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Beast Mastery Hunter DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=14287",
              "text": ""
            }
          ],
          "text": "will be the first ability you cast after your initial Auto Shot."
        },
        {
          "entities": [
            {
              "id": 27021,
              "name": "Multi-Shot",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=27021"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Beast Mastery Hunter DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=27021",
              "text": ""
            }
          ],
          "text": "should always be used when it is off cooldown. Pay attention to the situation and avoid using it when it will break crowd control."
        },
        {
          "entities": [
            {
              "id": 14266,
              "name": "Raptor Strike",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=14266"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Beast Mastery Hunter DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=14266",
              "text": ""
            }
          ],
          "text": "Should you choose to make things a little more interesting for yourself, you can use to fill in the gaps in your rotation."
        },
        {
          "entities": [
            {
              "id": 34120,
              "name": "Steady Shot",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=34120"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Beast Mastery Hunter DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=34120",
              "text": ""
            }
          ],
          "text": "will now be your primary ability to cast after each Auto Shot."
        },
        {
          "entities": [
            {
              "id": 34026,
              "name": "Kill Command",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=34026/kill-command"
            }
          ],
          "level_range": "66",
          "section": "Leveling Rotation for Beast Mastery Hunter DPS in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=34026/kill-command",
              "text": "Kill Command"
            }
          ],
          "text": "Once learned at level 66, you can fit Kill Command into your rotation every time it is available to use after a critical strike."
        }
      ],
      "heading": "Leveling Rotation for Beast Mastery Hunter DPS in Burning Crusade"
    },
