          ],
          "level_range": null,
          "section": "Leveling Rotation for Protection Warrior Tank in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=25203",
              "text": ""
            }
          ],
          "text": ": Demo Shout reduces incoming damage by ~18% and must always be applied on the boss."
        },
        {
          "entities": [
            {
