              "name": "Shield Slam",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=30356"
            }
          ],
          "level_range": null,
          "section": "Leveling Rotation for Protection Warrior Tank in Burning Crusade",
          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=30356",
              "text": ""
            }
          ],
          "text": ": Shield Slam is your highest threat ability and should be used on cooldown, never delayed."
        },
        {
          "entities": [
            {
