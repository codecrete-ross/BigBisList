          "source_links": [
            {
              "href": "https://www.wowhead.com/tbc/spell=25269",
              "text": ""
            }
          ],
          "text": ": Revenge should be used on cooldown."
        },
        {
          "entities": [
            {
              "id": 25203,
              "name": "Demoralizing Shout",
              "type": "spell",
              "url": "https://www.wowhead.com/tbc/spell=25203"
