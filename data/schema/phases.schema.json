{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Big BiS List phases",
  "type": "object",
  "required": ["phases"],
  "properties": {
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "name"],
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  }
}

