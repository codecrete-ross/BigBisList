{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Big BiS List reviewed overrides",
  "type": "object",
  "required": ["overrides"],
  "properties": {
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "reason", "reviewer", "reviewed_at", "source_url"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "target": { "type": "object" },
          "reason": { "type": "string" },
          "reviewer": { "type": "string" },
          "reviewed_at": { "type": "string" },
          "source_url": {
            "type": "string",
            "pattern": "^https://www\\.wowhead\\.com/tbc/"
          },
          "data": { "type": "object" }
        }
      }
    }
  }
}
